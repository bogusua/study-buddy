{
  "manifest_version": 3,
  "name": "Study Buddy",
  "version": "1.0.0",
  "description": "Інтерактивний тренажер для підготовки до вступних іспитів у ліцей",

  "permissions": [
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "side_panel.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Study Buddy",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}